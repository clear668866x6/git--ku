--- [4.2] LLVM IR 代码 ---
declare i32 @printf(ptr, ...)

@.fmt_num = private constant [4 x i8] c"%d\0A\00"


define i32 @main() {
entry:
  %i_ptr = alloca i32
  %sum_ptr = alloca i32
  br label %block0

block0:
  store i32 0, ptr %i_ptr
  store i32 0, ptr %sum_ptr
  store i32 0, ptr %i_ptr
  br label %block1

block1:
  %rt0 = load i32, ptr %i_ptr
  %brc_3 = icmp sge i32 %rt0, 10
  br i1 %brc_3, label %block8, label %block2

block2:
  %rt1 = load i32, ptr %i_ptr
  %brc_4 = icmp ne i32 %rt1, 3
  br i1 %brc_4, label %block4, label %block3

block3:
  br label %block7

block4:
  %rt2 = load i32, ptr %i_ptr
  %brc_6 = icmp ne i32 %rt2, 8
  br i1 %brc_6, label %block6, label %block5

block5:
  br label %block8

block6:
  %rt3 = load i32, ptr %sum_ptr
  %rt4 = load i32, ptr %i_ptr
  %t1 = add i32 %rt3, %rt4
  store i32 %t1, ptr %sum_ptr
  br label %block7

block7:
  %rt5 = load i32, ptr %i_ptr
  %t2 = add i32 %rt5, 1
  store i32 %t2, ptr %i_ptr
  br label %block1

block8:
  %rt6 = load i32, ptr %sum_ptr
  call i32 (ptr, ...) @printf(ptr @.fmt_num, i32 %rt6)
  %rt7 = load i32, ptr %sum_ptr
  ret i32 %rt7

}
