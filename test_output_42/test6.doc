--- [编译中端] 四元式流 ---
0: (=, 1, _, a)
1: (=, 0, _, b)
2: (=, 1, _, c)
3: (&&, a, b, t1)
4: (=, t1, _, r1)
5: (||, a, b, t2)
6: (=, t2, _, r2)
7: (&&, a, c, t3)
8: (||, t3, b, t4)
9: (=, t4, _, r3)
10: (write, r1, _, _)
11: (write, r2, _, _)
12: (write, r3, _, _)
13: (return, r3, _, _)

