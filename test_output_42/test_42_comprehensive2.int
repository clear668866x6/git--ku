--- [4.2] LLVM IR 代码 ---
declare i32 @printf(ptr, ...)

@.fmt_num = private constant [4 x i8] c"%d\0A\00"

@input_data = global [1 x i32] [i32 5]
@input_idx = global i32 0

define i32 @main() {
entry:
  %factor_ptr = alloca i32
  %n_ptr = alloca i32
  %result_ptr = alloca i32
  br label %block0

block0:
  %ld_0 = load i32, ptr @input_idx
  %gp_0 = getelementptr [1 x i32], ptr @input_data, i32 0, i32 %ld_0
  %t1 = load i32, ptr %gp_0
  %ni_0 = add i32 %ld_0, 1
  store i32 %ni_0, ptr @input_idx
  store i32 %t1, ptr %n_ptr
  %rt0 = load i32, ptr %n_ptr
  %brc_2 = icmp sgt i32 %rt0, 0
  br i1 %brc_2, label %block2, label %block1

block1:
  store i32 0, ptr %result_ptr
  br label %block5

block2:
  %rt1 = load i32, ptr %n_ptr
  %brc_5 = icmp sle i32 %rt1, 8
  br i1 %brc_5, label %block4, label %block3

block3:
  %t2 = sub i32 0, 1
  store i32 %t2, ptr %result_ptr
  br label %block5

block4:
  %rt2 = load i32, ptr %n_ptr
  %t3 = call i32 @factor(i32 %rt2)
  store i32 %t3, ptr %result_ptr
  br label %block5

block5:
  %rt3 = load i32, ptr %result_ptr
  call i32 (ptr, ...) @printf(ptr @.fmt_num, i32 %rt3)
  %rt4 = load i32, ptr %result_ptr
  ret i32 %rt4

}

define i32 @factor(i32 %m) {
entry:
  %fa_ptr = alloca i32
  %factor_ptr = alloca i32
  %m_ptr = alloca i32
  store i32 %m, ptr %m_ptr
  br label %block0

block0:
  %rt0 = load i32, ptr %m_ptr
  %brc_0 = icmp sgt i32 %rt0, 1
  br i1 %brc_0, label %block2, label %block1

block1:
  store i32 1, ptr %fa_ptr
  br label %block3

block2:
  %rt1 = load i32, ptr %m_ptr
  %t4 = sub i32 %rt1, 1
  %t5 = call i32 @factor(i32 %t4)
  %rt2 = load i32, ptr %m_ptr
  %t6 = mul i32 %rt2, %t5
  store i32 %t6, ptr %fa_ptr
  br label %block3

block3:
  %rt3 = load i32, ptr %fa_ptr
  ret i32 %rt3

}
