--- [4.2] LLVM IR 代码 ---
declare i32 @printf(ptr, ...)

@.fmt_num = private constant [4 x i8] c"%d\0A\00"

@input_data = global [6 x i32] [i32 5, i32 10, i32 3, i32 2, i32 1, i32 5]
@input_idx = global i32 0

define i32 @main() {
entry:
  %addAdjust_ptr = alloca i32
  %arr_ptr = alloca [100 x i32]
  %flag_ptr = alloca i32
  %i_ptr = alloca i32
  %n_ptr = alloca i32
  %result_ptr = alloca i32
  %sum_ptr = alloca i32
  br label %block0

block0:
  %ld_0 = load i32, ptr @input_idx
  %gp_0 = getelementptr [6 x i32], ptr @input_data, i32 0, i32 %ld_0
  %t1 = load i32, ptr %gp_0
  %ni_0 = add i32 %ld_0, 1
  store i32 %ni_0, ptr @input_idx
  store i32 %t1, ptr %n_ptr
  store i32 0, ptr %i_ptr
  store i32 0, ptr %sum_ptr
  store i32 1, ptr %flag_ptr
  br label %block1

block1:
  %rt0 = load i32, ptr %i_ptr
  %brc_5 = icmp sge i32 %rt0, 5
  br i1 %brc_5, label %block3, label %block2

block2:
  %ld_6 = load i32, ptr @input_idx
  %gp_6 = getelementptr [6 x i32], ptr @input_data, i32 0, i32 %ld_6
  %t2 = load i32, ptr %gp_6
  %ni_6 = add i32 %ld_6, 1
  store i32 %ni_6, ptr @input_idx
  %rt1 = load i32, ptr %i_ptr
  %gp_7 = getelementptr [100 x i32], ptr %arr_ptr, i32 0, i32 %rt1
  store i32 %t2, ptr %gp_7
  %rt2 = load i32, ptr %i_ptr
  %t3 = add i32 %rt2, 1
  store i32 %t3, ptr %i_ptr
  br label %block1

block3:
  store i32 0, ptr %i_ptr
  br label %block4

block4:
  %rt3 = load i32, ptr %i_ptr
  %brc_12 = icmp sge i32 %rt3, 5
  br i1 %brc_12, label %block11, label %block5

block5:
  %rt4 = load i32, ptr %i_ptr
  %gp_t4 = getelementptr [100 x i32], ptr %arr_ptr, i32 0, i32 %rt4
  %t4 = load i32, ptr %gp_t4
  %brc_14 = icmp sge i32 %t4, 0
  br i1 %brc_14, label %block7, label %block6

block6:
  br label %block10

block7:
  %rt5 = load i32, ptr %i_ptr
  %gp_t5 = getelementptr [100 x i32], ptr %arr_ptr, i32 0, i32 %rt5
  %t5 = load i32, ptr %gp_t5
  %brc_17 = icmp ne i32 %t5, 0
  br i1 %brc_17, label %block9, label %block8

block8:
  br label %block11

block9:
  %rt6 = load i32, ptr %i_ptr
  %gp_t6 = getelementptr [100 x i32], ptr %arr_ptr, i32 0, i32 %rt6
  %t6 = load i32, ptr %gp_t6
  %rt7 = load i32, ptr %sum_ptr
  %t7 = add i32 %rt7, %t6
  store i32 %t7, ptr %sum_ptr
  br label %block10

block10:
  %rt8 = load i32, ptr %i_ptr
  %t8 = add i32 %rt8, 1
  store i32 %t8, ptr %i_ptr
  br label %block4

block11:
  %rt9 = load i32, ptr %sum_ptr
  %t9 = add i32 %rt9, 1
  store i32 %t9, ptr %sum_ptr
  %rt10 = load i32, ptr %n_ptr
  %t10 = sub i32 %rt10, 1
  store i32 %t10, ptr %n_ptr
  %rt11 = load i32, ptr %n_ptr
  %brc_29 = icmp sgt i32 %rt11, 0
  br i1 %brc_29, label %block11, label %block12

block12:
  %rt12 = load i32, ptr %sum_ptr
  %t11_i1 = icmp sgt i32 %rt12, 10
  %t11 = zext i1 %t11_i1 to i32
  %rt13 = load i32, ptr %flag_ptr
  %t12_i1 = icmp eq i32 %rt13, 1
  %t12 = zext i1 %t12_i1 to i32
  %t13_c1 = icmp ne i32 %t11, 0
  %t13_c2 = icmp ne i32 %t12, 0
  %t13_b = and i1 %t13_c1, %t13_c2
  %t13 = zext i1 %t13_b to i32
  %rt14 = load i32, ptr %n_ptr
  %t14_i1 = icmp eq i32 %rt14, 0
  %t14 = zext i1 %t14_i1 to i32
  %t15_c1 = icmp ne i32 %t13, 0
  %t15_c2 = icmp ne i32 %t14, 0
  %t15_b = or i1 %t15_c1, %t15_c2
  %t15 = zext i1 %t15_b to i32
  %brc_35 = icmp eq i32 %t15, 0
  br i1 %brc_35, label %block14, label %block13

block13:
  %rt15 = load i32, ptr %sum_ptr
  %t16 = call i32 @addAdjust(i32 %rt15, i32 2)
  store i32 %t16, ptr %result_ptr
  br label %block15

block14:
  %rt16 = load i32, ptr %sum_ptr
  %t17 = sdiv i32 %rt16, 2
  %rt17 = load i32, ptr %sum_ptr
  %t18 = srem i32 %rt17, 2
  %t19 = add i32 %t17, %t18
  store i32 %t19, ptr %result_ptr
  br label %block15

block15:
  %rt18 = load i32, ptr %result_ptr
  call i32 (ptr, ...) @printf(ptr @.fmt_num, i32 %rt18)
  %rt19 = load i32, ptr %result_ptr
  ret i32 %rt19

}

define i32 @addAdjust(i32 %x, i32 %y) {
entry:
  %r_ptr = alloca i32
  %x_ptr = alloca i32
  %y_ptr = alloca i32
  store i32 %x, ptr %x_ptr
  store i32 %y, ptr %y_ptr
  br label %block0

block0:
  %rt0 = load i32, ptr %x_ptr
  %rt1 = load i32, ptr %y_ptr
  %t20 = add i32 %rt0, %rt1
  store i32 %t20, ptr %r_ptr
  %rt2 = load i32, ptr %r_ptr
  %brc_2 = icmp sle i32 %rt2, 20
  br i1 %brc_2, label %block2, label %block1

block1:
  %rt3 = load i32, ptr %r_ptr
  %t21 = sub i32 %rt3, 3
  store i32 %t21, ptr %r_ptr
  br label %block3

block2:
  %rt4 = load i32, ptr %r_ptr
  %t22 = add i32 %rt4, 3
  store i32 %t22, ptr %r_ptr
  br label %block3

block3:
  %rt5 = load i32, ptr %r_ptr
  ret i32 %rt5

}
